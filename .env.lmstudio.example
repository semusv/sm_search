APP_NAME=sap-rag
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sap_rag
# Внешний источник тикетов в Postgres (для /index-from-source)
SOURCE_SCHEMA=public
SOURCE_TABLE=tickets_source
SOURCE_TICKET_ID_COLUMN=ticket_id
SOURCE_QUESTION_COLUMN=user_question
SOURCE_ANSWER_COLUMN=support_answer
SOURCE_FUNCTIONAL_AREA_COLUMN=functional_area
EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=700
CHUNK_OVERLAP=120

ENABLE_VECTOR_SEARCH=true
ENABLE_RERANKING=true
ENABLE_FUZZY_SEARCH=true
ENABLE_LLM=true

VECTOR_TOP_K=20
RERANK_TOP_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
FUZZY_TOP_K=5
FUZZY_THRESHOLD=0.4
FINAL_CONTEXT_SIZE=7

# LM Studio работает через OpenAI-совместимый API.
LLM_PROVIDER=openai
LLM_MODEL=lmstudio-local-model
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000
LLM_TOP_P=0.95
LLM_API_KEY=lm-studio
# Для docker-контейнера search:
LLM_BASE_URL=http://host.docker.internal:1234/v1/chat/completions
# Для запуска search-сервиса локально вне Docker:
# LLM_BASE_URL=http://localhost:1234/v1/chat/completions
LLM_TIMEOUT_SECONDS=40
LLM_RETRIES=3
LLM_MODEL_PATH=

POSTGRES_DB=sap_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
